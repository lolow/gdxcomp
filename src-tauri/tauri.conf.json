{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gdxcomp",
  "version": "0.0.8",
  "identifier": "com.gdxcomp.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "gdxcomp — Plot & Compare GDX",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "resources": [],
    "category": "Utility",
    "shortDescription": "Plot and compare GAMS GDX files",
    "longDescription": "A desktop tool to load several GDX files and overlay, filter, and compare their symbols."
  }
}
